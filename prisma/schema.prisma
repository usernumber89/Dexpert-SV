generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  email               String        @unique
  role                Role          @default(STUDENT)
  onboardingCompleted Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  pyme                Pyme?
  student             Student?
  certificates        Certificate[]
}

enum Role {
  STUDENT
  PYME
  ADMIN
}

model Student {
  id             String      @id @default(cuid())
  userProfileId  String      @unique
  userProfile    UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  fullName       String?
  bio            String?
  education      String?
  skills         String?
  disabilityInfo String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  applications Application[]
  certificates Certificate[]
}

model Pyme {
  id          String      @id @default(cuid())
  userId      String      @unique
  userProfile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  name        String
  description String?
  contact     String?
  website     String?
  location    String?
  logoUrl     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projects Project[]
}

model Project {
  id          String    @id @default(cuid())
  pymeId      String
  pyme        Pyme      @relation(fields: [pymeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  skills      String
  category    String?
  level       String?
  imageUrl    String?
  isPublished Boolean   @default(false)
  status      String    @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]
}

model Application {
  id        String            @id @default(cuid())
  studentId String
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  certificate Certificate?

  @@unique([studentId, projectId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model Certificate {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy       String
  issuedById     String
  issuedByUser   UserProfile @relation(fields: [issuedById], references: [id])
  issueDate      DateTime    @default(now())
  certificateUrl String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}
